# ================================================
#  ERP Monorepo - Variables de Entorno (EJEMPLO)
#  Copia este archivo a .env en cada servicio
# ================================================

# --- API Gateway (backend/api-gateway/.env) ---
GATEWAY_PORT=3000
JWT_SECRET=erp-jwt-super-secreto-2024
USER_SERVICE_URL=http://localhost:3001
TICKETS_SERVICE_URL=http://localhost:3002
GROUPS_SERVICE_URL=http://localhost:3003
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# --- Backend ERP (backend/backend-erp/.env) ---
DATABASE_URL="postgresql://user:password@host:port/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:port/database"
ERP_PORT=3001
JWT_SECRET=erp-jwt-super-secreto-2024

# --- Tickets Service (backend/tickets-service/.env) ---
TICKETS_PORT=3002
DATABASE_URL="postgresql://user:password@host:port/database"

# --- Frontend (frontend/.env o environment.ts) ---
FRONTEND_PORT=4200
API_URL=http://localhost:3000
